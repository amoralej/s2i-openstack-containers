FROM registry.access.redhat.com/ubi10/ubi-minimal:latest

LABEL maintainer="OpenStack Kubernetes Operator team"

ARG CONSTRAINTS_FILE=requirements.lock

ENV LANG="en_US.UTF-8"
ENV TZ="UTC"
ENV container="oci"

USER root

COPY ${CONSTRAINTS_FILE} /deps-upper-constraints.txt
COPY rpms.repo /etc/yum.repos.d/rpms.repo

COPY bindeps.txt /tmp/bindeps.txt

RUN pkgs=$(cat /tmp/bindeps.txt | grep -v '^#' | grep -v '^$' | tr '\n' ' ') && \
    if [ -n "${pkgs}" ]; then microdnf -y install ${pkgs} && microdnf clean all && rm -rf /var/cache/dnf; fi && \
    rm /tmp/bindeps.txt

COPY pythondeps.txt /tmp/pythondeps.txt
RUN extrapkgs=$(cat /tmp/pythondeps.txt | grep -v '^#' | grep -v '^$' | tr '\n' ' ') && \
    pip3 install --no-cache-dir --prefix=/usr \
      -c /deps-upper-constraints.txt \
      ${extrapkgs} && \
    rm -rf /tmp/pythondeps.txt

# DNF configuration
RUN crudini --set /etc/dnf/dnf.conf main clean_requirements_on_remove True && \
    crudini --set /etc/dnf/dnf.conf main exactarch 1 && \
    crudini --set /etc/dnf/dnf.conf main gpgcheck 1 && \
    crudini --set /etc/dnf/dnf.conf main install_weak_deps False && \
    crudini --set /etc/dnf/dnf.conf main tsflags nodocs

# TLS cert symlink
RUN if [ ! -f "/etc/pki/tls/cert.pem" ]; then \
      ln -s /etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem /etc/pki/tls/cert.pem; \
    fi

# Install kolla helper scripts
COPY scripts/uid_gid_manage /usr/local/bin/uid_gid_manage
COPY scripts/kolla_set_configs /usr/local/bin/kolla_set_configs
COPY scripts/kolla_start /usr/local/bin/kolla_start
COPY scripts/kolla_httpd_setup /usr/local/bin/kolla_httpd_setup
COPY scripts/kolla_copy_cacerts /usr/local/bin/kolla_copy_cacerts
COPY scripts/sudoers /etc/sudoers
RUN chmod 755 /usr/local/bin/uid_gid_manage \
              /usr/local/bin/kolla_set_configs \
              /usr/local/bin/kolla_start \
              /usr/local/bin/kolla_httpd_setup \
              /usr/local/bin/kolla_copy_cacerts && \
    chmod 440 /etc/sudoers

# Create base users/groups (kolla + system groups needed by multiple services)
RUN uid_gid_manage kolla hugetlbfs libvirt qemu
RUN touch /usr/local/bin/kolla_extend_start && \
    chmod 755 /usr/local/bin/kolla_extend_start

# Fix nsswitch.conf
RUN sed -ri '/^(passwd:|group:)/ s/systemd//g' /etc/nsswitch.conf

# Create /openstack directory (convention from tcib)
RUN mkdir -p /openstack

# Final system update
RUN microdnf update -y && microdnf clean all && rm -rf /var/cache/dnf

STOPSIGNAL SIGTERM
ENTRYPOINT ["dumb-init", "--single-child", "--"]
CMD ["kolla_start"]
